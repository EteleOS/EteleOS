#!/bin/sh
#
# ltconfig: generate a system-specific "libtool" script.
# Part of the EteleOS build tools. No external license â€” written for
# EteleOS, which only targets amd64, arm64, riscv64 with Clang on
# EteleOS/OpenBSD (ELF, GNU-compatible ld via lld).
#
# Output format matches the variable names ltmain.sh expects, so the
# generated "libtool" script stays a drop-in replacement.
#
# Usage: ltconfig [OPTIONS] HOST LTMAIN

progname=$(basename "$0")
rm="rm -f"
ofile=libtool
srcdir=
host=
ltmain=
enable_shared=yes
enable_static=yes

usage() {
	cat <<EOF
Usage: $progname [OPTION]... HOST LTMAIN

Generate a system-specific libtool script for EteleOS.

    --disable-shared       do not build shared libraries
    --disable-static       do not build static libraries
-o, --output=FILE          specify the output file [default=$ofile]
    --srcdir=DIR           find config.guess/config.sub in DIR
    --help                 display this help and exit
EOF
}

while [ $# -gt 0 ]; do
	case "$1" in
	--help) usage; exit 0 ;;
	--disable-shared) enable_shared=no; shift ;;
	--disable-static) enable_static=no; shift ;;
	--srcdir=*) srcdir="${1#--srcdir=}"; shift ;;
	--srcdir) srcdir="$2"; shift 2 ;;
	-o|--output) ofile="$2"; shift 2 ;;
	--output=*) ofile="${1#--output=}"; shift ;;
	-*) echo "$progname: unrecognized option '$1'" >&2; exit 1 ;;
	*)
		if [ -z "$host" ]; then host="$1";
		elif [ -z "$ltmain" ]; then ltmain="$1";
		else echo "$progname: too many arguments" >&2; exit 1; fi
		shift
		;;
	esac
done

if [ -z "$ltmain" ]; then
	echo "$progname: you must specify HOST and LTMAIN" >&2
	usage >&2
	exit 1
fi
if [ ! -f "$ltmain" ]; then
	echo "$progname: '$ltmain' does not exist" >&2
	exit 1
fi

# Locate config.guess / config.sub.
srcdir=${srcdir:-$(dirname "$0")}
config_guess="$srcdir/config.guess"
config_sub="$srcdir/config.sub"
if [ ! -x "$config_guess" ] || [ ! -x "$config_sub" ]; then
	echo "$progname: cannot find config.guess/config.sub in $srcdir" >&2
	exit 1
fi

host_alias=$host
[ -z "$host_alias" ] && host_alias=$("$config_guess")
host=$("$config_sub" "$host_alias") || { echo "$progname: unrecognized host '$host_alias'" >&2; exit 1; }
host_cpu=$(echo "$host" | cut -d- -f1)
host_os=$(echo "$host" | cut -d- -f3-)

# EteleOS only ever builds with Clang, targeting ELF/EteleOS-OpenBSD.
CC=${CC-clang}
AR=${AR-llvm-ar}
RANLIB=${RANLIB-llvm-ranlib}
NM=${NM-llvm-nm}
LD=${LD-ld.lld}
OBJDUMP=${OBJDUMP-llvm-objdump}
LN_S="ln -s"
objdir=.libs
objext=o
libext=a
exeext=
pic_flag=" -fPIC"
can_build_shared=yes

# ELF shared-library conventions used across all three target CPUs.
archive_cmds='$CC -shared $libobjs $deplibs $linkopts -Wl,-soname,$soname -o $lib'
old_archive_cmds='$AR cru $oldlib $oldobjs~$RANLIB $oldlib'
hardcode_libdir_flag_spec='-Wl,-rpath,$libdir'
hardcode_direct=yes
hardcode_shlibpath_var=no
shlibpath_var=LD_LIBRARY_PATH
library_names_spec='${libname}${release}.so$versuffix ${libname}.so$versuffix'
soname_spec='${libname}${release}.so$versuffix'
version_type=sunos
deplibs_check_method=pass_all

[ "$can_build_shared" = no ] && enable_shared=no
[ "$enable_shared" = yes ] || enable_static=yes

echo "creating $ofile"
$rm "$ofile"
cat > "$ofile" <<EOF
#!$SHELL
# $ofile - EteleOS libtool wrapper.
# Generated by $progname for host: $host
### BEGIN LIBTOOL CONFIG

build_libtool_libs=$enable_shared
build_old_libs=$enable_static
host_alias=$host_alias
host=$host

CC=$CC
AR=$AR
RANLIB=$RANLIB
NM=$NM
LD=$LD
OBJDUMP=$OBJDUMP
LN_S=$LN_S

objdir=$objdir
objext=$objext
libext=$libext
exeext=$exeext
pic_flag=$pic_flag

archive_cmds=$archive_cmds
old_archive_cmds=$old_archive_cmds
hardcode_libdir_flag_spec=$hardcode_libdir_flag_spec
hardcode_direct=$hardcode_direct
hardcode_shlibpath_var=$hardcode_shlibpath_var
shlibpath_var=$shlibpath_var
library_names_spec=$library_names_spec
soname_spec=$soname_spec
version_type=$version_type
deplibs_check_method=$deplibs_check_method

### END LIBTOOL CONFIG
EOF

sed '$q' "$ltmain" >> "$ofile" || { rm -f "$ofile"; exit 1; }
chmod +x "$ofile"
exit 0
